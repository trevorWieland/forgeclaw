    "InitPayload": {
      "description": "`init` — initial context and configuration for processing a job.",
      "type": "object",
      "properties": {
        "config": {
          "description": "Provider proxy URL/token, model, limits.",
          "$ref": "#/$defs/InitConfig"
        },
        "context": {
          "description": "Message history, group info, timezone.",
          "$ref": "#/$defs/InitContext"
        },
        "job_id": {
          "description": "Unique job identifier for correlation with downstream messages.",
          "type": "string",
          "maxLength": 128,
          "minLength": 1,
          "pattern": "\\S"
        }
      },
      "required": [
        "job_id",
        "context",
        "config"
      ]
    },
    "MessagesPayload": {
      "description": "`messages` — follow-up messages that arrived while the container\nwas processing.",
      "type": "object",
      "properties": {
        "job_id": {
          "description": "Job identifier this follow-up belongs to.",
          "type": "string",
          "maxLength": 128,
          "minLength": 1,
          "pattern": "\\S"
        },
        "messages": {
          "description": "New historical messages to append to the context window.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/HistoricalMessage"
          },
          "maxItems": 256
        }
      },
      "required": [
        "job_id",
        "messages"
      ]
    },
    "ShutdownPayload": {
      "description": "`shutdown` — request graceful shutdown.",
      "type": "object",
      "properties": {
        "deadline_ms": {
          "description": "Deadline in milliseconds. After this deadline the host will\nforcibly terminate the container.",
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "reason": {
          "description": "Why the host is asking for shutdown.",
          "$ref": "#/$defs/ShutdownReason"
        }
      },
      "required": [
        "reason",
        "deadline_ms"
      ]
    },
    "ShutdownReason": {
      "description": "Why the host is asking the container to shut down.\n\nClosed enum on the wire — a value not in this list is a protocol\nerror.",
      "oneOf": [
        {
          "description": "The container was idle beyond its configured idle TTL.",
          "type": "string",
          "const": "idle_timeout"
        },
        {
          "description": "The host itself is shutting down.",
          "type": "string",
          "const": "host_shutdown"
        },
        {
          "description": "The warm pool evicted this container.",
          "type": "string",
          "const": "eviction"
        },
        {
          "description": "A failed job triggered a recover-by-restart path.",
          "type": "string",
          "const": "error_recovery"
        }
      ]
    }
  }
}
