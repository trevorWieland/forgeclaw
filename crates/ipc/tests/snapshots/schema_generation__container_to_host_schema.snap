  "$defs": {
    "BranchPolicy": {
      "description": "Branch strategy for self-improvement dispatches.",
      "oneOf": [
        {
          "description": "Create a new branch for the work.",
          "type": "string",
          "const": "create"
        },
        {
          "description": "Reuse an existing branch.",
          "type": "string",
          "const": "reuse"
        }
      ]
    },
    "CancelTaskPayload": {
      "description": "Cancel a previously scheduled task.",
      "type": "object",
      "properties": {
        "task_id": {
          "description": "Task to cancel.",
          "type": "string",
          "maxLength": 128,
          "minLength": 1,
          "pattern": "\\S"
        }
      },
      "required": [
        "task_id"
      ]
    },
    "CommandPayload": {
      "description": "`command` — IPC command from the agent to the host.",
      "type": "object",
