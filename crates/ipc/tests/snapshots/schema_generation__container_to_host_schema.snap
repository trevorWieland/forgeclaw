{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContainerToHost",
  "description": "A message sent from an agent container to the host.\n\nSerialized as an internally-tagged JSON object with a `type`\ndiscriminator. See [`docs/IPC_PROTOCOL.md`](../../../../docs/IPC_PROTOCOL.md)\n§Container → Host for the wire format.",
  "oneOf": [
    {
      "description": "`ready` — adapter has initialized and is ready to receive work.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "ready"
        }
      },
      "$ref": "#/$defs/ReadyPayload",
      "required": [
        "type"
      ]
    },
    {
      "description": "`output_delta` — incremental text chunk streamed from the model.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "output_delta"
        }
      },
      "$ref": "#/$defs/OutputDeltaPayload",
      "required": [
        "type"
      ]
    },
    {
      "description": "`output_complete` — final result for a job.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "output_complete"
        }
      },
      "$ref": "#/$defs/OutputCompletePayload",
      "required": [
        "type"
      ]
    },
    {
      "description": "`progress` — optional progress signal for long-running work.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "progress"
        }
      },
      "$ref": "#/$defs/ProgressPayload",
      "required": [
        "type"
      ]
    },
    {
      "description": "`command` — agent-to-host command (send message, schedule task,\ndispatch Tanren, etc.).",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "command"
        }
      },
      "$ref": "#/$defs/CommandPayload",
      "required": [
        "type"
      ]
    },
