---
source: crates/core/src/config/tests.rs
assertion_line: 30
expression: config
---
runtime:
  data_dir: /data
  log_level: info
  max_concurrent_containers: 5
  warm_pool_size: 2
  event_bus_capacity: 256
store:
  backend: sqlite
  url: "sqlite:///data/forgeclaw.db"
providers:
  anthropic:
    type: anthropic
    base_url: ~
  ollama:
    type: openai_compat
    base_url: "http://ollama:11434/v1"
budget_pools:
  shared:
    daily_limit: 2000000
    monthly_limit: 40000000
    action_on_exhaust: fallback
    alert_thresholds:
      - 0.8
      - 0.95
groups:
  guest:
    provider: ollama
    model: llama3
    fallback: []
    channel: discord
    is_main: false
    token_budget: ~
    budget_pool: ~
    allowed_compose_services: []
  main:
    provider: anthropic
    model: claude-sonnet-4-20250514
    fallback:
      - provider: ollama
        model: llama3
    channel: discord
    is_main: true
    token_budget:
      daily: 1000000
      monthly: 20000000
    budget_pool: shared
    allowed_compose_services:
      - postgres
      - tanren
      - redis
channels:
  discord:
    type: discord
    name: Main Discord Bot
    settings:
      guild_id: "123456789"
container:
  image: "ghcr.io/you/forgeclaw-agent:latest"
  timeout: 30m
  idle_ttl: 5m
  memory_limit: 4g
  cpu_limit: 2
tanren:
  api_url: "http://tanren:8000"
  poll_interval: 10s
  max_concurrent_dispatches: 4
